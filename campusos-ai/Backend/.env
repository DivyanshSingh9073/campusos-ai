# Backend environment variables
NODE_ENV=development
PORT=3001

# Required for Postgres
# Update this with your actual Postgres connection string

DATABASE_URL=postgresql://postgres:Acer%401239@localhost:5432/campusos

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# LLM (required for /api/ai/chat and /api/assistant/chat)
# Set this to your OpenAI API key
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# Optional
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
