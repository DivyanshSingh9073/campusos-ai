# Enforce consistent line endings for all contributors.
# This setting ensures that all text files are normalized to LF in the repository.
#
# text=auto: Git will handle the files in whatever way it thinks is best.
# eol=lf:   Enforces LF (Unix-style) line endings on commit.

* text=auto eol=lf

# For binary files, prevent Git from trying to normalize line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.eot binary
*.ttf binary
*.woff binary
*.woff2 binary